{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3001 -H 0.0.0.0",
    "dev:clean": "node -e \"require('fs').rmSync('.next-dev',{recursive:true,force:true})\" && next dev -p 3001 -H 0.0.0.0",
    "dev:rescue": "node scripts/dev-rescue.mjs && next dev -p 3001 -H 0.0.0.0",
    "build": "next build",
    "start": "next start -p 3001 -H 0.0.0.0",
    "preview": "next start -p 3001 -H 0.0.0.0",
    "lint": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:auth": "playwright test auth-boundary",
    "test:e2e:ui": "playwright test --ui",
    "ci:verify": "npm run lint && npm run build && npm run test:run",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "env:add-service-key": "node ./scripts/add_service_key.mjs",
    "env:use-emulator": "node ./scripts/use_emulator.mjs"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.3.0",
    "@light-story/api-types": "file:../packages/api-types",
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.105.4",
    "@tanstack/react-query": "^5.101.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "light-story-workspace": "file:..",
    "lucide-react": "^1.25.0",
    "motion": "^12.42.2",
    "next": "^16.2.10",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.2",
    "shadcn": "^4.13.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.5.4",
    "eslint": "10.7.0",
    "eslint-config-next": "16.2.10",
    "happy-dom": "^20.11.0",
    "supabase": "^2.109.1",
    "tailwindcss": "^4.2.3",
    "tsx": "^4.23.1",
    "typescript": "~7.0.2",
    "vitest": "^4.1.6"
  }
}
