{
  "name": "light-story-workspace",
  "private": true,
  "workspaces": [
    "packages/*",
    "frontend",
    "workers/*",
    "backend-supabase"
  ],
  "scripts": {
    "dev": "npm --prefix frontend run dev",
    "dev:gateway": "npx wrangler dev --port 8787 --config workers/unified-gateway/wrangler.jsonc",
    "dev:all": "concurrently -n fe,gw \"npm run dev\" \"npm run dev:gateway\"",
    "build": "npm --prefix frontend run build",
    "check": "npm --prefix frontend run build",
    "lint": "npm --prefix frontend run lint",
    "preview": "npm --prefix frontend run preview",
    "deploy": "wrangler deploy",
    "test:run": "npm --prefix frontend run test:run",
    "generate:types": "npm --prefix packages/api-types run generate",
    "docker:build": "docker compose build --no-cache",
    "docker:up": "docker compose up -d",
    "docker:rebuild": "docker compose down && docker compose build --no-cache && docker compose up -d"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260625.1",
    "@supabase/supabase-js": "^2.106.1",
    "concurrently": "^9.2.4",
    "husky": "^9.1.7",
    "wrangler": "^4.92.0"
  },
  "overrides": {
    "shell-quote": "1.10.0",
    "fast-uri": "4.1.1",
    "sharp": "0.35.3",
    "postcss": "8.5.22",
    "@hono/node-server": "2.0.11",
    "body-parser": "2.3.0",
    "**": {
      "postcss": "8.5.22",
      "sharp": "0.35.3",
      "@hono/node-server": "2.0.11"
    }
  }
}
